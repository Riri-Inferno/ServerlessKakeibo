# .env.prod - ラズパイ本番用環境変数
# このファイルはGitにコミットしない（.gitignoreに追加済み）

# === GAR イメージ参照 ===
GAR_IMAGE_BASE=asia-northeast1-docker.pkg.dev/yourpj/yourgar
IMAGE_TAG=latest

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpass
POSTGRES_DB=appdb

# === Backend ===
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=appdb;Username=postgres;Password=<上と同じ>

# === Cloudflare Tunnel ===
CLOUDFLARE_TUNNEL_TOKEN=<トンネルトークン>

# === GAR 認証（ラズパイから pull するため） ===
# 下記コマンドでログインしておく:
#   gcloud auth configure-docker asia-northeast1-docker.pkg.dev
