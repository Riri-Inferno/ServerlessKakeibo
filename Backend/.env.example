# ===========================================
# ServerlessKakeibo Backend 環境変数設定
# ===========================================
# このファイルをコピーして .env を作成してください:
#   cp Backend/.env.example Backend/.env
# その後、各項目を実際の値に置き換えてください

# ===========================================
# データベース設定
# ===========================================
# Docker環境の場合（docker-compose.yml のdbサービスを使用）
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=appdb;Username=postgres;Password=Password

# ローカル開発の場合
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=appdb;Username=postgres;Password=YourPassword

# ===========================================
# GCP認証設定（ADC: Application Default Credentials）
# ===========================================
# ローカル開発:
#   1) ホストで一度だけ実行: gcloud auth application-default login
#   2) docker-compose.yml が ~/.config/gcloud をコンテナにマウントする
#   3) 下の GOOGLE_APPLICATION_CREDENTIALS でマウント先のパスを指す
#
# 本番 (k3s):
#   WIF JSON を ConfigMap でマウントし、同じ環境変数でパス指定
GOOGLE_APPLICATION_CREDENTIALS=/gcp/adc/application_default_credentials.json
GcpAuth__DefaultScopes__0=https://www.googleapis.com/auth/cloud-platform
GcpAuth__UseCache=True
GcpAuth__CacheDurationMinutes=60

# ===========================================
# Vertex AI設定（レシートOCR用）
# ===========================================
# GCPプロジェクトIDを設定
# 取得方法: https://console.cloud.google.com/ のプロジェクト選択から確認
VertexAi__ProjectId=YOUR_GCP_PROJECT_ID

# ===========================================
# Google Cloud Storage設定（レシート画像保存用）
# ===========================================
# GCSバケット名を設定
# 作成方法: https://console.cloud.google.com/storage
GcpStorage__BucketName=YOUR_BUCKET_NAME
GcpStorage__ProjectId=YOUR_GCP_PROJECT_ID
GcpStorage__IsPublicBucket=false
GcpStorage__GenerateSignedUrl=true
GcpStorage__SignedUrlExpirationHours=1
# 署名付きURL生成用 SA email（IAM signBlob 経由で署名）
# 認証主体（user/WIF）はこのSAに対して
# roles/iam.serviceAccountTokenCreator を持つ必要あり
# 詳細: Document/Development/iam-signer-setup.md
GcpStorage__SignerServiceAccount=YOUR_SIGNER_SA@YOUR_GCP_PROJECT_ID.iam.gserviceaccount.com

# ===========================================
# Google AI Studio設定（オプション）
# ===========================================
# Vertex AIの代わりにGoogle AI Studioを使用する場合のみ設定
# 取得方法: https://aistudio.google.com/app/apikey
GoogleAiStudio__ApiKey=YOUR_GOOGLE_AI_STUDIO_API_KEY

# ===========================================
# 認証設定
# ===========================================

# --- JWT設定 ---
# SecretKeyは32文字以上のランダムな文字列を設定してください
# 生成コマンド例:
#   openssl rand -base64 32
#   または
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
Authentication__Jwt__SecretKey=PLEASE_GENERATE_A_STRONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
Authentication__Jwt__Issuer=ServerlessKakeiboApi
Authentication__Jwt__Audience=ServerlessKakeiboApp
Authentication__Jwt__ExpirationMinutes=15
Authentication__Jwt__RefreshTokenExpirationDays=7

# --- Google OAuth設定 ---
# 取得方法:
# 1. https://console.cloud.google.com/apis/credentials にアクセス
# 2. 「認証情報を作成」→「OAuthクライアントID」
# 3. アプリケーションの種類: ウェブアプリケーション
# 4. 承認済みのリダイレクトURI: http://localhost:3000/auth/callback
Authentication__Google__ClientId=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# --- GitHub OAuth設定 ---
# 取得方法:
# 1. https://github.com/settings/developers にアクセス
# 2. 「New OAuth App」をクリック
# 3. Authorization callback URL: http://localhost:3000/auth/callback
Authentication__GitHub__ClientId=YOUR_GITHUB_CLIENT_ID
Authentication__GitHub__ClientSecret=YOUR_GITHUB_CLIENT_SECRET

# ===========================================
# その他の設定
# ===========================================
#未使用
DefaultTenantId=deadeade-0001-0000-0000-000000000001

# ===========================================
# 環境設定
# ===========================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
